}
df_result <- rbind(df_result, data.frame(
ASR = rowMeans(temp_asr) / p,
SSR = rowMeans(temp_ssr) / p,
lambda = 1:100, p = p,
Corr_type = ifelse(rho_type == 1, "Type 1", "Type 2"),
Type = ifelse(type == 5, "AR", "Block AR")
))
}
}
}
run_sim[[1]]$beta
