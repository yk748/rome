paste0("p=", df_long$p, ", n=", df_long$n),
levels = c(
"p=100, n=100", "p=100, n=500", "p=100, n=1000",
"p=500, n=100", "p=500, n=500", "p=500, n=1000",
"p=1000, n=100", "p=1000, n=500", "p=1000, n=1000"))
